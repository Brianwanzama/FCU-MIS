# Copy this file to .env and fill in real values. Never commit the real .env file.

# --- Core Django ---
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL) ---
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:devpassword@localhost:5432/fcu_mis

# --- Email (account activation notices, password reset) ---
# For local dev, leave EMAIL_BACKEND as the console backend so emails print to the terminal.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@fcu-mis.local

# --- FCU business defaults (fallbacks only — admins override via System Settings, FR-14) ---
FCU_DEFAULT_MONTHLY_SAVINGS=100000
FCU_DEFAULT_MONTHLY_EMERGENCY=5000
FCU_DEFAULT_LOAN_INTEREST_PERCENT=5.0
FCU_DEFAULT_MAX_LOAN_AMOUNT=2000000
FCU_DEFAULT_MAX_LOAN_PERCENT_OF_CONTRIBUTIONS=75.0
